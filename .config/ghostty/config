# Current problems
# - no workspace support
# - no tabs support when using without title bar
# - bad theme support
# - aerospace treats each tab as a window halvening size on each new one

# Dynamic theme colors
config-file = ?"~/.config/omarchy/current/theme/ghostty.conf"

# Font
font-family = "JetBrains Mono NL"
font-style = Regular
font-size = 10

# Window
# window-padding-x = 14
# window-padding-y = 14
confirm-close-surface=false
resize-overlay = never

# Cursor styling
cursor-style = "block"
cursor-style-blink = false
shell-integration-features = no-cursor

# Tab
macos-titlebar-style = hidden
macos-option-as-alt = true
gtk-titlebar = false

# keybinds
keybind = ctrl+a>l=goto_split:right
keybind = ctrl+a>h=goto_split:left
keybind = ctrl+a>j=goto_split:bottom
keybind = ctrl+a>k=goto_split:top
keybind = ctrl+a>v=new_split:right
keybind = ctrl+a>x=new_split:down
keybind = ctrl+a>z=toggle_split_zoom

keybind = super+h=goto_split:left
keybind = super+j=goto_split:bottom
keybind = super+k=goto_split:top
keybind = super+l=goto_split:right
keybind = super+n=next_tab
keybind = super+p=previous_tab

# keybind = ctrl+a>==reset_font_size
keybind = shift+insert=paste_from_clipboard
keybind = control+insert=copy_to_clipboard
keybind = super+control+shift+alt+arrow_down=resize_split:down,100
keybind = super+control+shift+alt+arrow_up=resize_split:up,100
keybind = super+control+shift+alt+arrow_left=resize_split:left,100
keybind = super+control+shift+alt+arrow_right=resize_split:right,100

# Slowdown mouse scrolling
mouse-scroll-multiplier = 0.95
